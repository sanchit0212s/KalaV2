<section class="section-a py-20 relative">
  <div class="absolute inset-0 bg-rangoli pointer-events-none opacity-40"></div>

  <div class="max-w-[1400px] mx-auto px-6 relative">
    <!-- Section header -->
    <div class="text-center mb-14" data-animate>
      <p class="section-label mb-3">{{ section.settings.label | default: 'Designed for Your Space' }}</p>
      <h2 class="font-display text-3xl md:text-4xl text-on-surface font-light">
        {{ section.settings.heading | default: 'Where they live in your home' }}
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-12 gap-4 auto-rows-[200px] md:auto-rows-[240px]">

      {%- for block in section.blocks -%}
        {%- case forloop.index -%}
          {%- when 1 -%}
            {%- assign cell_class = 'col-span-6 md:col-span-4 row-span-2' -%}
            {%- assign img_width = 800 -%}
          {%- when 2 -%}
            {%- assign cell_class = 'col-span-6 md:col-span-8 row-span-1' -%}
            {%- assign img_width = 1200 -%}
          {%- when 3 -%}
            {%- assign cell_class = 'col-span-6 md:col-span-4 row-span-1' -%}
            {%- assign img_width = 800 -%}
          {%- when 4 -%}
            {%- assign cell_class = 'col-span-6 md:col-span-4 row-span-1' -%}
            {%- assign img_width = 800 -%}
          {%- else -%}
            {%- assign cell_class = 'col-span-6 md:col-span-4 row-span-1' -%}
            {%- assign img_width = 800 -%}
        {%- endcase -%}

        <div class="{{ cell_class }} rounded-lg overflow-hidden relative group" data-animate {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: img_width }}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
          {%- endif -%}
          <div class="absolute inset-0 bg-gradient-to-t from-obsidian/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4 right-4">
            <p class="font-display text-base text-white mb-0.5">{{ block.settings.title }}</p>
            <p class="font-body text-[10px] text-white/60 tracking-wider uppercase">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Room Gallery",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Designed for Your Space"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where they live in your home"
    }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Room",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Room title",
          "default": "The Entryway"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Deity subtitle",
          "default": "Ganesh · Remover of Obstacles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Room Gallery",
      "blocks": [
        { "type": "room", "settings": { "title": "The Entryway", "subtitle": "Ganesh · Remover of Obstacles" } },
        { "type": "room", "settings": { "title": "The Living Room", "subtitle": "Shiva Nataraja · Force of Transformation" } },
        { "type": "room", "settings": { "title": "The Quiet Corner", "subtitle": "Buddha · Embodiment of Stillness" } },
        { "type": "room", "settings": { "title": "The Study", "subtitle": "Saraswati · Flow of Knowledge" } }
      ]
    }
  ]
}
{% endschema %}
